{
  "name": "sky-king",
  "version": "1.0.0",
  "type": "module",
  "description": "SKY KING — לוח שמיים, מערכת ניהול סטריפים לתעופה",
  "main": "electron-main.cjs",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "concurrently -n server,vite -c green,cyan \"node server.js\" \"vite\"",
    "dev:unix": "node server.js & vite",
    "server": "node server.js",
    "start": "node server.js",
    "client": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:linux": "npm run build && electron-builder --linux",
    "mirage": "node mirage/server.js"
  },
  "build": {
    "appId": "com.skyking.app",
    "productName": "SKY KING",
    "copyright": "SKY KING — לוח שמיים",
    "files": [
      "dist/**",
      "electron-main.cjs",
      "server.js",
      "node_modules/**",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "config.example.json",
        "to": "config.example.json"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SKY KING"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@replit/connectors-sdk": "^0.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^10.0.3",
    "electron": "^36.1.0",
    "electron-builder": "^25.1.8",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.0.15",
    "@types/react-dom": "^18.0.6",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.23.26",
    "i18next": "^23.16.8",
    "iink-ts": "^3.3.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.562.0",
    "pdfjs-dist": "^5.6.205",
    "pg": "^8.16.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^13.5.0",
    "tailwind-merge": "^3.4.0",
    "tesseract.js": "^7.0.0",
    "typescript": "^4.7.4",
    "vite": "^5.4.21",
    "xlsx": "^0.18.5"
  }
}
